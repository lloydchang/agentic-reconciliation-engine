# =============================================================================
# GitOps Infrastructure Control Plane - Environment Variables Template
# =============================================================================
# 
# This file contains environment variables required for the AI Agent Skills
# and MCP servers. Copy this file to .env and fill in your actual values.
# 
# IMPORTANT: Never commit the .env file with real credentials to version control!
# =============================================================================

# =============================================================================
# Cloud Provider Credentials
# =============================================================================

# AWS Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Azure Credentials
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_CLIENT_SECRET=your_azure_client_secret_here
AZURE_TENANT_ID=your_azure_tenant_id_here
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id_here

# Google Cloud Platform Credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_ORGANIZATION_ID=your_gcp_organization_id_here

# =============================================================================
# Monitoring and Alerting Systems
# =============================================================================

# Prometheus
PROMETHEUS_URL=https://prometheus.company.com
PROMETHEUS_USERNAME=your_prometheus_username
PROMETHEUS_PASSWORD=your_prometheus_password

# Datadog
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_APP_KEY=your_datadog_app_key_here

# PagerDuty
PAGERDUTY_API_KEY=your_pagerduty_api_key_here

# Grafana
GRAFANA_URL=https://grafana.company.com
GRAFANA_API_KEY=your_grafana_api_key_here

# =============================================================================
# Communication Platforms
# =============================================================================

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your-slack-signing-secret-here
SLACK_APP_TOKEN=xapp-your-slack-app-token-here

# Microsoft Teams
TEAMS_WEBHOOK_URL=https://your-teams-webhook-url-here
TEAMS_CLIENT_ID=your_teams_client_id_here
TEAMS_CLIENT_SECRET=your_teams_client_secret_here
TEAMS_TENANT_ID=your_teams_tenant_id_here

# Email Configuration
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=alerts@company.com
SMTP_PASSWORD=your_email_password_here
SMTP_USE_TLS=true

# =============================================================================
# Project Management Systems
# =============================================================================

# Jira
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# Asana
ASANA_API_KEY=your_asana_api_key_here
ASANA_WORKSPACE_ID=your_asana_workspace_id_here

# Trello
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
TRELLO_BOARD_ID=your_trello_board_id_here

# =============================================================================
# Development Platforms
# =============================================================================

# GitHub
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username
GITHUB_ORG=your_github_organization

# GitLab
GITLAB_TOKEN=your_gitlab_personal_access_token_here
GITLAB_URL=https://gitlab.company.com

# =============================================================================
# Cost Estimation and Analytics
# =============================================================================

# Infracost
INFRACOST_API_KEY=your_infracost_api_key_here
INFRACOST_PRICING_API_ENDPOINT=https://pricing.api.infracost.io

# Custom Pricing API
PRICING_API_KEY=your_pricing_api_key_here
PRICING_API_URL=https://api.pricing.company.com

# Analytics Platforms
ANALYTICS_API_KEY=your_analytics_api_key_here
DASHBOARD_URL=https://dashboards.company.com
METRICS_API_URL=https://metrics.company.com

# =============================================================================
# Database and Storage
# =============================================================================

# Vector Database (for Knowledge Base)
VECTOR_DB_URL=your_vector_database_url_here
VECTOR_DB_API_KEY=your_vector_db_api_key_here
VECTOR_DB_INDEX_NAME=knowledge_base

# PostgreSQL (for incident tracking and decision history)
POSTGRES_URL=postgresql://username:password@localhost:5432/knowledge_base
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_base
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# Redis (for caching)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# Security and Compliance
# =============================================================================

# OpenAI API (for LLM-based analysis)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# Security Scanning
SECURITY_SCAN_API_KEY=your_security_scan_api_key_here
VULNERABILITY_DB_URL=https://vulnerability-db.company.com

# Compliance Tools
COMPLIANCE_API_KEY=your_compliance_api_key_here
COMPLIANCE_FRAMEWORK_URL=https://compliance.company.com

# =============================================================================
# Knowledge Base and Document Processing
# =============================================================================

# Document Processing
DOCUMENT_PROCESSING_TIMEOUT=300
MAX_DOCUMENT_SIZE=50MB
EMBEDDING_MODEL=text-embedding-ada-002

# Knowledge Base Configuration
KNOWLEDGE_BASE_PATH=/data/knowledge-base
BACKUP_SCHEDULE="0 2 * * *"
RETENTION_DAYS=365

# Search Configuration
DEFAULT_SEARCH_LIMIT=10
SIMILARITY_THRESHOLD=0.7
MAX_SEARCH_RESULTS=100

# =============================================================================
# MCP Server Configuration
# =============================================================================

# MCP Server Ports
MCP_CLOUD_COMPLIANCE_PORT=3001
MCP_INCIDENT_TRIAGE_PORT=3002
MCP_IAC_VALIDATOR_PORT=3003
MCP_KNOWLEDGE_BASE_PORT=3004
MCP_ENGAGEMENT_SYNC_PORT=3005

# MCP Server Logging
MCP_LOG_LEVEL=info
MCP_LOG_FILE=/var/log/mcp-servers.log
MCP_DEBUG=false

# MCP Server Security
MCP_API_KEY=your_mcp_api_key_here
MCP_ENABLE_AUTH=true
MCP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# AI Agent Skills Configuration
# =============================================================================

# Skill Execution
SKILL_EXECUTION_TIMEOUT=300
SKILL_MAX_MEMORY=2GB
SKILL_PARALLEL_WORKERS=4

# Skill Logging
SKILL_LOG_LEVEL=info
SKILL_LOG_FORMAT=json
SKILL_ENABLE_METRICS=true

# Skill Cache
SKILL_CACHE_TTL=3600
SKILL_CACHE_SIZE=1GB
SKILL_CACHE_BACKEND=redis

# =============================================================================
# Claude Desktop Integration
# =============================================================================

# Claude Desktop Configuration
CLAUDE_DESKTOP_CONFIG_PATH=~/.config/claude-desktop/config.json
CLAUDE_DESKTOP_LOG_LEVEL=info
CLAUDE_DESKTOP_ENABLE_TELEMETRY=false

# MCP Server Paths for Claude Desktop
MCP_SERVER_BASE_PATH=/Users/lloyd/github/antigravity/gitops-infra-control-plane/.claude/mcp-servers
MCP_NODE_PATH=/usr/local/bin/node

# =============================================================================
# Development and Testing
# =============================================================================

# Development Mode
DEV_MODE=false
DEBUG=false
VERBOSE=false

# Testing Configuration
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/test_db
TEST_REDIS_URL=redis://localhost:6379/1
TEST_VECTOR_DB_URL=http://localhost:8080

# Mock Services (for testing)
USE_MOCK_SERVICES=false
MOCK_AWS_API=false
MOCK_AZURE_API=false
MOCK_GCP_API=false

# =============================================================================
# Performance and Monitoring
# =============================================================================

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
METRICS_COLLECTION_INTERVAL=60
PERFORMANCE_LOG_FILE=/var/log/performance.log

# Health Checks
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_ENDPOINTS=/health,/metrics,/api/health

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# =============================================================================
# Backup and Recovery
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# Recovery Configuration
RECOVERY_POINT_RETENTION_HOURS=24
AUTO_RECOVERY_ENABLED=false
DISASTER_RECOVERY_URL=https://recovery.company.com

# =============================================================================
# Integration and Webhooks
# =============================================================================

# Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_ATTEMPTS=3

# Integration Endpoints
INTEGRATION_API_BASE_URL=https://api.company.com
INTEGRATION_API_VERSION=v1
INTEGRATION_TIMEOUT=60

# =============================================================================
# Miscellaneous
# =============================================================================

# Time Zone
TZ=UTC

# Locale
LANG=en_US.UTF-8

# Application Name and Version
APP_NAME=gitops-infra-control-plane
APP_VERSION=1.0.0

# Feature Flags
FEATURE_CLOUD_COMPLIANCE=true
FEATURE_INCIDENT_TRIAGE=true
FEATURE_IAC_VALIDATOR=true
FEATURE_KNOWLEDGE_BASE=true
FEATURE_ENGAGEMENT_SYNC=true

# =============================================================================
# Instructions for Use
# =============================================================================
#
# 1. Copy this file to .env:
#    cp .env.template .env
#
# 2. Edit the .env file and replace placeholder values with your actual credentials
#
# 3. Set appropriate file permissions:
#    chmod 600 .env
#
# 4. Add .env to your .gitignore file to prevent accidental commits:
#    echo ".env" >> .gitignore
#
# 5. Source the environment variables in your shell:
#    source .env
#
# 6. Or use a tool like direnv to automatically load environment variables
#
# SECURITY NOTES:
# - Never commit the .env file with real credentials to version control
# - Use strong, unique passwords and API keys
# - Rotate credentials regularly
# - Use environment-specific .env files for different deployments
# - Consider using a secrets management system for production deployments
#
# =============================================================================
