# Grafana Admin Credentials SealedSecret Template
# Generate with: kubectl create secret generic grafana-admin-credentials --from-literal=admin-password=your-secure-password --dry-run=client -o yaml | kubeseal --format yaml > grafana-secret-sealed.yaml
---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: grafana-admin-credentials
  namespace: monitoring
  labels:
    app.kubernetes.io/name: grafana
    app.kubernetes.io/part-of: gitops-infra-control-plane
spec:
  encryptedData:
    admin-password: [GENERATE_WITH_KUBESEAL_COMMAND]
  template:
    metadata:
      name: grafana-admin-credentials
      namespace: monitoring
      labels:
        app.kubernetes.io/name: grafana
        app.kubernetes.io/part-of: gitops-infra-control-plane
    type: Opaque
