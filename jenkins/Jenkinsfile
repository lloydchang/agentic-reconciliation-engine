// Jenkins Pipeline for GitOps Infrastructure Control Plane
// This pipeline builds OCI images and integrates with Flux for continuous deployment

// Configuration - adjust these values for your environment
dockerRepoHost = 'ghcr.io'
dockerRepoUser = '${{ github.repository_owner }}'
dockerRepoProj = 'gitops-infra-control-plane'

// Jenkins secret ID for Docker registry credentials
jenkinsDockerSecret = 'ghcr-registry-account'

// Pipeline variables (filled in by stages)
gitCommit = ''
branchName = ''
unixTime = ''
developmentTag = ''
releaseTag = ''

pipeline {
    agent {
        kubernetes { 
            yamlFile "jenkins/docker-pod.yaml" 
            defaultContainer 'docker'
        }
    }
    
    environment {
        // Environment variables for the pipeline
        DOCKER_REPO_HOST = "${dockerRepoHost}"
        DOCKER_REPO_USER = "${dockerRepoUser}"
        DOCKER_REPO_PROJ = "${dockerRepoProj}"
        GIT_COMMIT = "${env.GIT_COMMIT}"
        BRANCH_NAME = "${env.BRANCH_NAME}"
    }
    
    stages {
        // Build Docker image locally for testing
        stage('Build') {
            steps {
                script {
                    gitCommit = env.GIT_COMMIT.substring(0,8)
                    branchName = env.BRANCH_NAME
                    unixTime = (new Date().time.intdiv(1000))
                    developmentTag = "${branchName}-${gitCommit}-${unixTime}"
                    env.DEVELOPMENT_IMAGE = "${dockerRepoHost}/${dockerRepoUser}/${dockerRepoProj}:${developmentTag}"
                    
                    echo "Building development image: ${env.DEVELOPMENT_IMAGE}"
                    echo "Git commit: ${gitCommit}"
                    echo "Branch: ${branchName}"
                    echo "Timestamp: ${unixTime}"
                }
                
                sh """
                    echo "🔨 Building Docker image..."
                    docker build -t ${env.DEVELOPMENT_IMAGE} ./ \\
                        --label git-commit=${gitCommit} \\
                        --label branch=${branchName} \\
                        --label build-time=${unixTime}
                    
                    echo "✅ Docker image built successfully"
                    docker images | grep ${dockerRepoProj}
                """
            }
        }
        
        // Push development image and run tests in parallel
        stage('Development') {
            parallel {
                // Push development tag for non-release branches
                stage('Push Development Tag') {
                    when {
                        not {
                            buildingTag()
                        }
                    }
                    steps {
                        withCredentials([[$class: 'UsernamePasswordMultiBinding',
                            credentialsId: jenkinsDockerSecret,
                            usernameVariable: 'DOCKER_REPO_USER',
                            passwordVariable: 'DOCKER_REPO_PASSWORD']]) {
                            sh """
                                echo "🔐 Logging into Docker registry..."
                                echo ${DOCKER_REPO_PASSWORD} | docker login ${dockerRepoHost} -u ${DOCKER_REPO_USER} --password-stdin
                                
                                echo "📤 Pushing development image..."
                                docker push ${env.DEVELOPMENT_IMAGE}
                                
                                echo "✅ Development image pushed successfully"
                                echo "Image: ${env.DEVELOPMENT_IMAGE}"
                            """
                        }
                    }
                }
                
                // Run tests in a new pod with the built image
                stage('Test') {
                    agent {
                        kubernetes {
                            yaml """
                                apiVersion: v1
                                kind: Pod
                                spec:
                                  containers:
                                  - name: test
                                    image: ${env.DEVELOPMENT_IMAGE}
                                    imagePullPolicy: Never
                                    securityContext:
                                      runAsUser: 1000
                                      runAsGroup: 1000
                                      allowPrivilegeEscalation: false
                                      readOnlyRootFilesystem: true
                                    command:
                                    - cat
                                    resources:
                                      requests:
                                        memory: 256Mi
                                        cpu: 100m
                                      limits:
                                        memory: 1Gi
                                        cpu: 500m
                                    tty: true
                                    env:
                                    - name: NODE_ENV
                                      value: test
                            """.stripIndent()
                        }
                    }
                    options { skipDefaultCheckout(true) }
                    steps {
                        container('test') {
                            sh """
                                echo "🧪 Running tests in container..."
                                
                                # Run basic container health checks
                                echo "Checking container health..."
                                python --version || echo "Python not available"
                                node --version || echo "Node.js not available"
                                
                                # Run application-specific tests if available
                                if [ -f "/app/jenkins/run-tests.sh" ]; then
                                    echo "Running application tests..."
                                    /app/jenkins/run-tests.sh
                                else
                                    echo "No test script found, running basic validation..."
                                    # Basic container validation
                                    ls -la /app || echo "No /app directory"
                                    ps aux || echo "No process listing available"
                                fi
                                
                                echo "✅ Tests completed successfully"
                            """
                        }
                    }
                }
            }
        }
        
        // Push release tag for git tags (production releases)
        stage('Release') {
            when {
                buildingTag()
            }
            steps {
                script {
                    releaseTag = env.TAG_NAME
                    env.RELEASE_IMAGE = "${dockerRepoHost}/${dockerRepoUser}/${dockerRepoProj}:${releaseTag}"
                    
                    echo "🚀 Processing release tag: ${releaseTag}"
                    echo "Release image: ${env.RELEASE_IMAGE}"
                }
                
                withCredentials([[$class: 'UsernamePasswordMultiBinding',
                    credentialsId: jenkinsDockerSecret,
                    usernameVariable: 'DOCKER_REPO_USER',
                    passwordVariable: 'DOCKER_REPO_PASSWORD']]) {
                    sh """
                        echo "🔐 Logging into Docker registry for release..."
                        echo ${DOCKER_REPO_PASSWORD} | docker login ${dockerRepoHost} -u ${DOCKER_REPO_USER} --password-stdin
                        
                        echo "🏷️ Tagging release image..."
                        docker tag ${env.DEVELOPMENT_IMAGE} ${env.RELEASE_IMAGE}
                        
                        echo "📤 Pushing release image..."
                        docker push ${env.RELEASE_IMAGE}
                        
                        echo "✅ Release image pushed successfully"
                        echo "Development: ${env.DEVELOPMENT_IMAGE}"
                        echo "Release: ${env.RELEASE_IMAGE}"
                        
                        # Also push latest tag for main branch releases
                        if [ "${branchName}" = "main" ]; then
                            echo "📤 Pushing latest tag..."
                            docker tag ${env.RELEASE_IMAGE} ${dockerRepoHost}/${dockerRepoUser}/${dockerRepoProj}:latest
                            docker push ${dockerRepoHost}/${dockerRepoUser}/${dockerRepoProj}:latest
                            echo "✅ Latest tag updated"
                        fi
                    """
                }
            }
        }
        
        // Update GitOps manifests with new image references
        stage('Update GitOps') {
            when {
                anyOf {
                    buildingTag()
                    branch 'main'
                }
            }
            steps {
                script {
                    if (buildingTag()) {
                        echo "🔄 Updating GitOps manifests for release: ${releaseTag}"
                        env.IMAGE_TAG = releaseTag
                    } else if (branchName == 'main') {
                        echo "🔄 Updating GitOps manifests for development: ${developmentTag}"
                        env.IMAGE_TAG = developmentTag
                    }
                }
                
                // This stage would typically trigger Flux ImageUpdateAutomation
                // or update image references in manifests
                sh """
                    echo "📝 Image tag for GitOps: ${env.IMAGE_TAG}"
                    echo "🔄 Flux will detect the new image and update manifests automatically"
                    
                    # Optional: Create a commit to trigger Flux immediately
                    # git config user.name "Jenkins CI"
                    # git config user.email "jenkins@ci.local"
                    # echo "Image updated to ${env.IMAGE_TAG}" > build-info.txt
                    # git add build-info.txt
                    # git commit -m "🔄 Update image tag to ${env.IMAGE_TAG}"
                    # git push origin ${branchName}
                """
            }
        }
    }
    
    post {
        success {
            echo "✅ Pipeline completed successfully!"
            echo "📊 Build Summary:"
            echo "  - Branch: ${branchName}"
            echo "  - Commit: ${gitCommit}"
            if (buildingTag()) {
                echo "  - Release: ${releaseTag}"
                echo "  - Release Image: ${env.RELEASE_IMAGE}"
            } else {
                echo "  - Development Tag: ${developmentTag}"
                echo "  - Development Image: ${env.DEVELOPMENT_IMAGE}"
            }
        }
        
        failure {
            echo "❌ Pipeline failed!"
            echo "🔍 Check the logs above for error details"
            echo "📊 Build Summary:"
            echo "  - Branch: ${branchName}"
            echo "  - Commit: ${gitCommit}"
            if (buildingTag()) {
                echo "  - Release: ${releaseTag}"
            } else {
                echo "  - Development Tag: ${developmentTag}"
            }
        }
        
        cleanup {
            echo "🧹 Cleaning up..."
            sh """
                # Clean up Docker images to save space
                docker system prune -f || true
                echo "🧹 Docker cleanup completed"
            """
        }
    }
}
