# Environment file for Agent Memory Service
# Copy this to .env and update values as needed

# Database Configuration
DATABASE_PATH=sqlite:/data/memory.db

# Server Configuration
BIND_ADDRESS=0.0.0.0
PORT=8080
RUST_LOG=agent_memory=debug,tower_http=debug

# LLM Backend Configuration
# Priority order: llamacpp,openai,ollama
BACKEND_PRIORITY=llamacpp,openai,ollama

# LLaMA.cpp Configuration (for local inference)
LLAMACPP_API_URL=http://localhost:8080
LLAMACPP_MODEL=qwen2.5:0.5b

# Qwen LLM Configuration (fallback options)
QWEN_API_URL=http://localhost:8000
QWEN_MODEL=qwen2.5:0.5b
QWEN_API_KEY=agent-memory-api-key

# Ollama Configuration (alternative fallback)
OLLAMA_API_URL=http://localhost:11434

# Skills Configuration
SKILLS_DIRECTORY=/opt/skills

# Authentication
JWT_SECRET=qwen-jwt-secret-for-agent-memory
AUTH_ENABLED=true
API_KEYS=flagger-api-key,k8sgpt-api-key,flux-api-key

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
MAX_CONNECTIONS=1000

# Backend Priority
BACKEND_PRIORITY=llamacpp,openai,ollama
LANGUAGE_PRIORITY=rust,go,python
MODEL=qwen2.5:0.5b
