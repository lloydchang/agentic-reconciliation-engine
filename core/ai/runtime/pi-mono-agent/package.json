{
  "name": "pi-mono-agent-container",
  "version": "1.0.0",
  "description": "Pi-Mono containerized agent for GitOps Control Plane - Third agent execution method",
  "main": "index.js",
  "scripts": {
    "build": "docker build -t gitops-infra-control-plane/pi-mono-agent:latest .",
    "run": "docker run -p 8080:8080 --env-file .env gitops-infra-control-plane/pi-mono-agent:latest",
    "test": "docker run --rm gitops-infra-control-plane/pi-mono-agent:latest pi --version",
    "k8s:deploy": "kubectl apply -f k8s/",
    "k8s:delete": "kubectl delete -f k8s/",
    "k8s:logs": "kubectl logs -f deployment/pi-mono-agent -n ai-infrastructure",
    "health": "curl -X POST http://localhost:8080 -H 'Content-Type: application/json' -d '{\"type\":\"ping\"}'"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^1.0.0"
  },
  "keywords": [
    "pi-mono",
    "ai-agent",
    "gitops",
    "kubernetes",
    "container",
    "rpc",
    "temporal-alternative"
  ],
  "author": "GitOps Control Plane Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lloydchang/gitops-infra-control-plane"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
