# SonarQube Credentials SealedSecret Template
# Generate with: kubectl create secret generic sonarqube-credentials --from-literal=admin-password=your-secure-admin-password --from-literal=postgres-password=your-secure-postgres-password --dry-run=client -o yaml | kubeseal --format yaml > sonarqube-secret-sealed.yaml
---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: sonarqube-credentials
  namespace: testing
  labels:
    app.kubernetes.io/name: sonarqube
    app.kubernetes.io/part-of: gitops-infra-control-plane
spec:
  encryptedData:
    admin-password: [GENERATE_WITH_KUBESEAL_COMMAND]
    postgres-password: [GENERATE_WITH_KUBESEAL_COMMAND]
  template:
    metadata:
      name: sonarqube-credentials
      namespace: testing
      labels:
        app.kubernetes.io/name: sonarqube
        app.kubernetes.io/part-of: gitops-infra-control-plane
    type: Opaque
