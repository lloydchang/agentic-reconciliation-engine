---
# Age Key Secret Template for Flux SOPS Decryption
# This secret contains the private age key that Flux uses to decrypt secrets
# Copy to age-key-secret.yaml and fill in the actual private key

apiVersion: v1
kind: Secret
metadata:
  name: sops-age-key
  namespace: flux-system
type: Opaque
stringData:
  # Private age key for SOPS decryption
  # Generate with: age-keygen -o age-key.txt
  # Copy the private key here (the line starting with "AGE-SECRET-KEY-1...")
  age.agekey: |
    # created: 2026-03-13T13:30:00Z
    # public key: age1flc7ff4p8k3qyz4ks7dhyk9srx2h2g5n4q2qz4q2qz4q2qz4q2qz
    AGE-SECRET-KEY-1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

---
# Alternative: Use Kubernetes secret for age key
# This approach allows storing the key in external secret management
apiVersion: v1
kind: Secret
metadata:
  name: sops-age-key-ref
  namespace: flux-system
type: Opaque
annotations:
  # For External Secrets Operator integration
  external-secrets.io/secret-key: "age-private-key"
  # For Azure Key Vault integration
  azure-key-vault-uri: "https://your-kv.vault.azure.net/"
  # For AWS Secrets Manager integration
  aws-secrets-manager-secret: "gitops-sops-age-key"
