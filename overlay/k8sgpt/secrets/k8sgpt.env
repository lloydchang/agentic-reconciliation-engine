# K8sGPT Secrets Configuration
# Copy this file to k8sgpt.env.local and fill in actual values

# Qwen LLM Configuration
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=http://qwen-server:8000
QWEN_MODEL=qwen2.5-7b-instruct

# Optional: If using external Qwen API
# QWEN_EXTERNAL_API_KEY=your-external-api-key
# QWEN_EXTERNAL_BASE_URL=https://your-qwen-provider.com

# Alert Configuration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
PAGERDUTY_API_KEY=your-pagerduty-api-key

# Monitoring Configuration (Optional)
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000

# Database Configuration (Optional for caching)
REDIS_URL=redis://redis:6379
POSTGRES_URL=postgresql://user:password@postgres:5432/k8sgpt
